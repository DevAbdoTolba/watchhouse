# BitVision / Cantonk DVR
DVR_IP=192.168.1.10
DVR_PORT=554
DVR_USER=admin
DVR_PASS=changeme

# Optional: which stream each tile starts on (sub or main). Default: sub.
CAM1_DEFAULT=sub
CAM2_DEFAULT=sub
CAM3_DEFAULT=sub
CAM4_DEFAULT=sub

# --- Recorder (v0.2.0) ---
# Set RECORDING_ENABLED=0 to disable the local recorder entirely.
RECORDING_ENABLED=1
# Default is <env_dir>/recordings; set an absolute path here to override.
# RECORDING_DIR=D:\Watchhouse\recordings
# Which stream to record. sub = ~100 KB/s/cam (recommended); main = full quality, much heavier.
RECORDING_STREAM=sub
# Segment length in minutes. Each segment is a self-contained MP4.
RECORDING_SEGMENT_MINUTES=30
# Auto-delete segments older than this many days.
RECORDING_RETENTION_DAYS=7
